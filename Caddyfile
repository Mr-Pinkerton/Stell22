# Caddy автоматически получает и продлевает HTTPS-сертификаты (Let's Encrypt)
# и проксирует запросы в приложение. Основной домен берётся из DOMAIN.
{$DOMAIN} {
	encode gzip
	reverse_proxy app:3000
}

# www-версия редиректит на основной домен (один канонический адрес для
# сессий/SEO). Caddy сам выпустит сертификат и для www.
www.{$DOMAIN} {
	redir https://{$DOMAIN}{uri} permanent
}
