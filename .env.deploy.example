# Настройки прод-развёртывания (docker-compose.prod.yml).
# Скопируйте этот файл в .env НА СЕРВЕРЕ и заполните значения.
# Файл .env НЕ коммитить — в нём секреты.

# Ваш домен (без http://). Заранее направьте его A-записью на IP сервера.
DOMAIN=stell22.example.ru

# Пароль пользователя базы данных. Придумайте длинный случайный.
#   Сгенерировать:  openssl rand -base64 24
POSTGRES_PASSWORD=change-me-strong-db-password

# Секрет для подписи cookie-сессий (минимум 32 байта).
#   Сгенерировать:  openssl rand -base64 32
SESSION_SECRET=change-me-generate-with-openssl-rand-base64-32

# (Необязательно) Мониторинг ошибок Sentry. Оставьте пустым, если не нужен.
# DSN берётся в проекте Sentry: Settings → Projects → Client Keys (DSN).
SENTRY_DSN=

# ── Приём банковских выписок с почты (необязательно) ────────────────────────
# Если банк присылает выписки 1С (.txt/.zip) на выделенный ящик — скрипт по
# cron (scripts/fetch-statements.ts) раз в час заберёт их и импортирует.
# Оставьте MAIL_IMAP_HOST пустым, чтобы приём был отключён.
#
# Секрет для защиты cron-эндпойнта приёма (/api/cron/fetch-statements).
# Без него эндпойнт отключён. Сгенерировать:  openssl rand -hex 24
CRON_SECRET=

# Параметры IMAP берутся в панели почты (у Beget — «Настройки почтовых программ»).
MAIL_IMAP_HOST=
MAIL_IMAP_PORT=993
# true — сразу SSL/TLS (порт 993, обычно так). false — STARTTLS.
MAIL_IMAP_SECURE=true
MAIL_IMAP_USER=tochka@stell22.ru
MAIL_IMAP_PASSWORD=
# Папка, откуда читать письма. Обычно INBOX.
MAIL_IMAP_MAILBOX=INBOX
# Белый список отправителей через запятую (адрес банка). Пусто = принимать
# от любого отправителя. Защита от постороннего письма с поддельным «файлом
# выписки». Для банка «Точка» отправитель — informer@tochka.com.
MAIL_ALLOWED_SENDERS=informer@tochka.com
# Помечать письмо прочитанным после обработки (иначе разберём его снова).
MAIL_MARK_SEEN=true
