# Скопируйте в .env и при необходимости поправьте значения.
# Локальная БД поднимается через docker-compose (см. docker-compose.yml).
DATABASE_URL="postgresql://stell22:stell22@localhost:5434/stell22?schema=public"

# Секрет для подписи cookie-сессий (JWT HS256). Сгенерировать:
#   openssl rand -base64 32
SESSION_SECRET="change-me-dev-secret-change-me-dev-secret"

# Пароль администратора для сида локальной БД (npm run db:seed).
SEED_ADMIN_PASSWORD="admin123"
